<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HitAScreen.App.OverlayWindow"
        Classes="overlay-window">
  <Grid Name="RootGrid" IsHitTestVisible="True">
    <Border Name="FrameBorder" Classes="overlay-frame" />
    <Canvas Name="HintCanvas"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            IsHitTestVisible="False" />
    <TextBlock Name="StatusText" Classes="overlay-status" />
  </Grid>
</Window>
