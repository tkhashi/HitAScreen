<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HitAScreen.App.MainWindow"
        Width="900"
        Height="700"
        MinWidth="720"
        MinHeight="520"
        CanResize="True">
  <Grid RowDefinitions="Auto,*" Margin="16">
    <TextBlock Text="HitAScreen Control Panel" FontSize="22" FontWeight="SemiBold" />

    <Grid Row="1" ColumnDefinitions="2*,3*" ColumnSpacing="16" Margin="0,16,0,0">
      <Border BorderThickness="1" BorderBrush="#304050" CornerRadius="8" Padding="12">
        <ScrollViewer>
          <StackPanel Spacing="10">
            <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" />

            <TextBlock Text="Hotkey" />
            <TextBox Name="HotkeyTextBox" IsReadOnly="True" />

            <TextBlock Text="Default Analysis Target" />
            <ComboBox Name="TargetComboBox" SelectedIndex="0">
              <ComboBoxItem Content="ActiveMonitor" />
              <ComboBoxItem Content="ActiveWindow" />
            </ComboBox>

            <TextBlock Text="Label Character Set" />
            <TextBox Name="LabelCharsetTextBox" />

            <TextBlock Text="Label Scale (0.5 - 3.0)" />
            <TextBox Name="LabelScaleTextBox" />

            <CheckBox Name="SuppressFullscreenCheckBox" Content="Suppress hotkey when fullscreen window is active" />
            <CheckBox Name="ContinuousModeCheckBox" Content="Continuous mode (stay in overlay after action)" />
            <CheckBox Name="DebugLoggingCheckBox" Content="Enable persistent debug log" />

            <TextBlock Text="Suppressed Processes (comma separated, e.g. Vivaldi, Steam)" TextWrapping="Wrap" />
            <TextBox Name="SuppressedProcessTextBox" AcceptsReturn="True" Height="90" />

            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Name="SaveSettingsButton" Content="Save Settings" />
              <Button Name="RequestPermissionButton" Content="Request Permissions" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Name="StartSessionButton" Content="Start Session" />
              <Button Name="ReanalyzeButton" Content="Reanalyze" />
              <Button Name="CancelSessionButton" Content="Cancel Session" />
            </StackPanel>

            <TextBlock Name="StatusTextBlock" Text="Ready" TextWrapping="Wrap" />
          </StackPanel>
        </ScrollViewer>
      </Border>

      <Border Grid.Column="1" BorderThickness="1" BorderBrush="#304050" CornerRadius="8" Padding="12">
        <Grid RowDefinitions="Auto,*" RowSpacing="8">
          <TextBlock Text="Diagnostics" FontSize="18" FontWeight="SemiBold" />
          <TextBox Grid.Row="1" Name="DiagnosticsTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" />
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
